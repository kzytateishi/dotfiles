[core]
  editor = nvim
  precomposeunicode = true
  quotepath = false

[color]
  ui = auto

[column]
  ui = auto
	status = never

[help]
  autocorrect = prompt

[init]
  defaultBranch = main

[diff]
  renames = true
  colorMoved = default
  algorithm = histogram

[merge]
  conflictstyle = zdiff3
  ff = false
  directoryRenames = conflict

[pull]
  rebase = true

[push]
  default = current
  autoSetupRemote = true

[fetch]
  prune = true
  pruneTags = true

[rebase]
  autostash = true
  autosquash = true

[rerere]
  enabled = true

[branch]
  sort = -committerdate
  autoSetupMerge = always

[tag]
  sort = -version:refname

[alias]
  # Status
  st = status
  ss = status -sb

  # Commit / Branch
  ci = commit
  ca = commit --amend
  can = commit --amend --no-edit
  co = checkout
  cob = checkout -b
  sw = switch
  swc = switch -c
  br = branch
  bvv = branch -vv
  cp = cherry-pick
  cur = rev-parse --abbrev-ref HEAD
  up = rev-parse --abbrev-ref --symbolic-full-name @{u}

  # Log
  lg = log --graph --all --decorate --abbrev-commit --date=short --pretty=format:'%C(red)%h%C(reset) %C(green)[%ad]%C(reset) %s %C(cyan)@%an%C(reset)%C(yellow)%d%C(reset)'
  lo = log --oneline -20
  graph = log --graph --decorate --oneline
  last = log -1 --stat
  show1 = show --stat --oneline HEAD

  # Diff
  dm = diff @{upstream}
  dc = diff --cached
  d1 = diff HEAD~
  d2 = diff HEAD~~
  dw = diff --word-diff
  ds = diff --stat
  name = diff --name-only
  cname = diff --cached --name-only

  # Reset / Restore
  r = reset
  r1 = reset HEAD^
  r2 = reset HEAD^^
  rh = reset --hard
  rh1 = reset HEAD^ --hard
  rh2 = reset HEAD^^ --hard
  rs = restore
  rss = restore --staged

  # Stash
  sl = stash list
  sp = stash pop
  stm = stash push -m

  # Push / Fetch
  p = push
  pf = push --force-with-lease
  fp = fetch --prune --prune-tags

  # Utility
  tags = tag -l
  undo = reset --soft HEAD^
  wip = "!git add -A && git commit -m 'wip'"
  fixup = commit --fixup
  squash = commit --squash
  merged = branch --merged main
  unmerged = branch --no-merged main
  cop = "!git for-each-ref --format='%(refname:short)' refs/heads | fzf --reverse | xargs -r git switch"

  clear = "!f() { target=\"${1:-main}\"; current=\"$(git symbolic-ref --short HEAD)\"; git checkout \"$target\" && git fetch -p && for branch in $(git for-each-ref --format='%(refname:short)' refs/heads/); do [ \"$branch\" = \"$target\" ] && continue; [ \"$branch\" = \"$current\" ] && continue; [ \"$branch\" = \"main\" ] && continue; [ \"$branch\" = \"master\" ] && continue; [ \"$branch\" = \"develop\" ] && continue; if git merge-base --is-ancestor \"$branch\" \"$target\"; then echo \"delete (merged): git branch -d $branch\"; elif ! git ls-remote --exit-code --heads origin \"$branch\" >/dev/null 2>&1; then echo \"delete (not on origin): git branch -D $branch\"; fi; done; }; f"

  clear-run = "!f() { target=\"${1:-main}\"; current=\"$(git symbolic-ref --short HEAD)\"; git checkout \"$target\" && git fetch -p && for branch in $(git for-each-ref --format='%(refname:short)' refs/heads/); do [ \"$branch\" = \"$target\" ] && continue; [ \"$branch\" = \"$current\" ] && continue; [ \"$branch\" = \"main\" ] && continue; [ \"$branch\" = \"master\" ] && continue; [ \"$branch\" = \"develop\" ] && continue; if git merge-base --is-ancestor \"$branch\" \"$target\"; then printf \"Delete (merged): %s? [y/N] \" \"$branch\"; read ans; [ \"$ans\" = \"y\" ] && git branch -d \"$branch\"; elif ! git ls-remote --exit-code --heads origin \"$branch\" >/dev/null 2>&1; then printf \"Delete (not on origin): %s? [y/N] \" \"$branch\"; read ans; [ \"$ans\" = \"y\" ] && git branch -D \"$branch\"; fi; done; }; f"

[include]
  path = ~/.gitconfig.local

[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
